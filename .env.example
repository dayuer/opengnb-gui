# ═══════════════════════════════════════════════════════════════
# SynonClaw Console — 环境变量模板
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# --- 认证 ---
ADMIN_TOKEN=                    # 管理员 API Token（留空则启动时自动生成并输出到终端）

# --- 服务 ---
PORT=3000                       # HTTP 监听端口
DATA_DIR=./data                 # 数据根目录（所有持久化数据的父目录）
NODE_ENV=production             # 运行环境 (production / development)

# --- GNB 节点配置 ---
GNB_NODE_ID=1001                # Console 自身的 GNB 节点 ID
GNB_CONF_DIR=/opt/gnb/conf/1001 # GNB 配置文件目录
GNB_TUN_ADDR=198.18.0.1          # Console 的 TUN 内网地址
GNB_TUN_SUBNET=198.18.0.0/16     # 弹性 TUN 候选子网（默认 RFC 2544 /16 测试保留段）
GNB_INDEX_NODES=                # GNB Index 节点地址列表（逗号分隔）

# --- SSH 凭证（自动管理） ---
# 首次启动时自动生成 ED25519 密钥对，存储在:
#   ${DATA_DIR}/security/ssh/console_ed25519      (私钥)
#   ${DATA_DIR}/security/ssh/console_ed25519.pub  (公钥)
# 需将公钥部署到终端节点 synon 用户的 ~/.ssh/authorized_keys
# JWT Secret 由私钥 SHA256 哈希自动推导，无需手动配置

# --- 部署配置（deploy.sh / setup-console.sh 使用） ---
DEPLOY_SERVER=                  # 部署目标服务器 IP（如 43.156.128.95）
DEPLOY_SSH_USER=root            # SSH 部署用户
DEPLOY_DOMAIN=                  # 域名（如 api.synonclaw.com）
DEPLOY_APP_DIR=/opt/gnb-console # 服务器上的应用目录
DEPLOY_BRANCH=main              # Git 部署分支
DEPLOY_PORT=3000                # 服务器端口（需与 PORT 一致）
CERTBOT_EMAIL=                  # Let's Encrypt SSL 证书邮箱

# --- 监控 ---
POLL_INTERVAL_MS=10000          # 节点状态轮询间隔（毫秒）
STALE_TIMEOUT_MS=60000          # 节点离线判定超时（毫秒，默认 60s = 6 次上报周期）

# --- 数据目录结构（自动创建，无需手动配置） ---
# ${DATA_DIR}/
# ├── registry/              — 核心业务数据
# │   └── nodes.db           — SQLite (nodes, groups, metrics, audit_logs, users, jobs)
# ├── security/              — 安全凭证
# │   ├── ssh/               — SSH 密钥对
# │   └── backups/           — 节点数据自动备份
# ├── logs/                  — 运维日志
# │   └── ops/               — AI-Ops 对话记录
# └── mirror/                — 软件分发镜像
#     ├── gnb/               — GNB 二进制
#     └── openclaw/          — OpenClaw 包
