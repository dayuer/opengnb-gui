# SynonClaw Console 环境变量示例
# 复制此文件为 .env 并填入实际值

# --- 认证 ---
ADMIN_TOKEN=              # 管理员认证 Token（留空则启动时自动生成）

# --- 服务 ---
PORT=3000
DATA_DIR=./data
NODE_ENV=production

# --- GNB 节点配置 ---
GNB_NODE_ID=1001
GNB_CONF_DIR=/opt/gnb/conf/1001
GNB_TUN_ADDR=10.1.0.1
GNB_INDEX_NODES=

# --- 部署配置（deploy.sh 使用） ---
DEPLOY_SERVER=            # 部署目标服务器 IP
DEPLOY_DOMAIN=            # 域名（如 api.synonclaw.com）
CERTBOT_EMAIL=            # Let's Encrypt 证书邮箱

# --- 监控 ---
POLL_INTERVAL_MS=10000
