{
  "name": "gnb-console",
  "version": "0.1.0",
  "description": "GNB Node Management Console — SSH-based remote monitoring via GNB TUN network",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "tsx src/server.ts",
    "test": "node --import tsx --test 'src/__tests__/**/*.test.js'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gnb",
    "vpn",
    "management",
    "console"
  ],
  "license": "GPL-3.0",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0",
    "ssh2": "^1.16.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
